# Copy this file to `.env` and fill in real values. Never commit `.env`.

# Gmail IMAP used to ingest LinkedIn job alert emails
LINKEDIN_EMAIL=your.address@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# LLM providers (used by the writing / analysis pipeline)
# Primary: Anthropic. Required.
ANTHROPIC_API_KEY=
# Fallback 1: OpenAI. Used automatically if Anthropic credits are exhausted
# or the call fails. Strongly recommended.
OPENAI_API_KEY=

# Optional: browser automation for semi-auto submission
# Path to a Playwright user-data directory so LinkedIn stays logged in between runs
PLAYWRIGHT_USER_DATA_DIR=./.playwright-user-data
